# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real secrets.

# ── Supabase ── (Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── NextAuth / Auth.js ──
# Generate a secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# ── Google OAuth ── (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
